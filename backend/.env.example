# Default fallback key if specific ones aren't provided
GROQ_API_KEY=your_default_groq_api_key_here

# The 5 specialized API keys (one for each agent to bypass rate limits)
GROQ_KEY_SUPERVISOR=your_supervisor_groq_api_key_here
GROQ_KEY_DB=your_database_groq_api_key_here
GROQ_KEY_BACKEND=your_backend_groq_api_key_here
GROQ_KEY_FRONTEND=your_frontend_groq_api_key_here
GROQ_KEY_ASSEMBLER=your_assembler_groq_api_key_here
